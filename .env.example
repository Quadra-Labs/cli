# Quadra Assistant CLI — every value is optional; the defaults below are the live
# testnet deployment. Override only for a local stack or a different deployment.
# The CLI NEVER reads a private key from env: wallets live in the encrypted keystore.

# --- Quadra services ---------------------------------------------------------
# Data gateway (agent discovery, templates, sealed results). 30s warm-up tolerated.
DATA_GATEWAY_URL=https://api.quadra.sh
# Intake engine (jobs are opened by agents; the CLI does not call this directly in v1).
INTAKE_URL=https://intake.quadra.sh

# --- On-chain (published quadra package) -------------------------------------
QUADRA_PACKAGE_ID=0x6350b090b44ca4d1c4884e3de24868a462bc3201911d7ca9457e68251bd4ac46
AGENT_REGISTRY_ID=0x572320726d1cde2c829b243e1f30e9d9996ae4e9f1ca62a28d9288075b6b4a99
JOB_ACCESS_REGISTRY_ID=0x352c6aa35f0ea957b89b6476c14eecca52ed6ac5e633b0c9ee2d4356703cd21e

# --- Sui / Seal --------------------------------------------------------------
WALRUS_NETWORK=testnet
# Empty -> the public fullnode for the network is used.
SUI_RPC_URL=
# Comma-separated open-mode Seal key server object ids. Empty -> the built-in pair.
SEAL_KEY_SERVER_IDS=
SEAL_THRESHOLD=1

# --- Quadra Assistant (concierge LLM) ----------------------------------------
# The assistant uses OpenAI to understand what you need and route you to the best
# agent. Without a key the CLI still works in manual browse mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Keystore ----------------------------------------------------------------
# Where encrypted wallets live. Default: ~/.quadra
QUADRA_HOME=
